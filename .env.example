# Spotify Web API credentials (from developer.spotify.com)
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# Your Spotify login credentials (for librespot device)
SPOTIFY_USERNAME=your_spotify_email
SPOTIFY_PASSWORD=your_spotify_password

# Your playlist URI or link
PLAYLIST_URI=https://open.spotify.com/playlist/your_playlist_id

# OAuth redirect URI (your Northflank service URL + /callback)
REDIRECT_URI=https://your-service.northflank.app/callback

# Server port (Northflank sets this automatically)
PORT=3000

# Device name (shown in Spotify Connect)
DEVICE_NAME=SpotifyBot-24-7
